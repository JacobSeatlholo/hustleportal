\fs20 // \uc0\u9472 \u9472  HUSTLE QUIZ \u9472 \u9472 
\fs24 \

\fs20 const QUESTIONS = [
\fs24 \

\fs20 \{ q:'How many hours do you work on your business per week?', opts:['0\'965 hrs','6\'9615 hrs','16\'9630 hrs','30+ hrs'], scores:[5,15,25,40] \},
\fs24 \

\fs20 \{ q:'Do you have a website or online presence?', opts:['Not yet','Social only','Website (basic)','Full digital presence'], scores:[0,10,20,30] \},
\fs24 \

\fs20 \{ q:'How do you find new customers?', opts:['Word of mouth only','Some social posting','Consistent marketing','Paid + organic strategy'], scores:[5,10,20,30] \},
\fs24 \

\fs20 ];
\fs24 \

\fs20 let qStep = 0, qAnswers = [];
\fs24 \

\fs20 function renderQuiz() \{
\fs24 \

\fs20 const wrap = document.getElementById('hustleQuiz');
\fs24 \

\fs20 const q = QUESTIONS[qStep];
\fs24 \

\fs20 wrap.innerHTML = `<div class="progress-bar">$\{QUESTIONS.map((_,i)=>`<div class="prog-seg $\{i<=qStep?'done':''\}"></div>`).join('')\}</div><div class="q-num">Question $\{qStep+1\} of $\{QUESTIONS.length\}</div><div class="q-text">$\{q.q\}</div><div class="q-options">$\{q.opts.map((o,i)=>`<button class="q-opt" onclick="pickAnswer($\{q.scores[i]\})">$\{o\}</button>`).join('')\}</div>`;
\fs24 \

\fs20 \}
\fs24 \

\fs20 function pickAnswer(score) \{
\fs24 \

\fs20 qAnswers.push(score);
\fs24 \

\fs20 if (qStep < QUESTIONS.length - 1) \{ qStep++; renderQuiz(); \}
\fs24 \

\fs20 else \{ showResult(); \}
\fs24 \

\fs20 \}
\fs24 \

\fs20 function showResult() \{
\fs24 \

\fs20 const total = qAnswers.reduce((a,b)=>a+b,0);
\fs24 \

\fs20 const max = QUESTIONS.reduce((a,q)=>a+Math.max(...q.scores),0);
\fs24 \

\fs20 const pct = Math.round((total/max)*100);
\fs24 \

\fs20 const [emoji,label,msg,color] = pct<30?['\cf2 \cb3 \strokec2 {{\NeXTGraphic Attachment.png \width320 \height320 \appleattachmentpadding0 \appleembedtype0 \appleaqc
}¬}\cf2 \cb3 \strokec2 ','Seedling','You\\'re just getting started \'97 let\\'s plant the right seeds.','#34d399']:pct<60?['\cf2 \cb3 \strokec2 {{\NeXTGraphic Attachment.png \width320 \height320 \appleattachmentpadding0 \appleembedtype0 \appleaqc
}¬}\cf2 \cb3 \strokec2 ','Side Hustler','You\\'ve got momentum. Time to turn up the heat!','#fb923c']:pct<85?['\cf2 \cb3 \strokec2 {{\NeXTGraphic Attachment.png \width320 \height320 \appleattachmentpadding0 \appleembedtype0 \appleaqc
}¬}\cf2 \cb3 \strokec2 ','Grind Mode','You\\'re serious. Let\\'s take you to the next level!','#F5C518']:['\cf2 \cb3 \strokec2 {{\NeXTGraphic Attachment.png \width320 \height320 \appleattachmentpadding0 \appleembedtype0 \appleaqc
}¬}\cf2 \cb3 \strokec2 ','Full Hustle','You\\'re an absolute machine. Let\\'s scale this empire.','#a78bfa'];
\fs24 \

\fs20 document.getElementById('hustleQuiz').style.display='none';
\fs24 \

\fs20 const res = document.getElementById('hustleResult');
\fs24 \

\fs20 res.style.display='block';
\fs24 \

\fs20 res.innerHTML=`<div class="result-emoji">$\{emoji\}</div><div class="result-score" style="color:$\{color\}">$\{pct\}% Hustle</div><div class="result-label">$\{label\}</div><div class="result-msg">$\{msg\}</div><div class="result-bar-wrap"><div class="result-bar" style="width:$\{pct\}%;background:linear-gradient(90deg,$\{color\},#F5C518)"></div></div><div class="result-btns"><a href="{\field{\*\fldinst{HYPERLINK "https://www.businesshustle.co.za/get-started"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 https://www.businesshustle.co.za/get-started}}" target="_blank" class="result-btn-primary">\cf2 \cb3 \strokec2 {{\NeXTGraphic Attachment.png \width320 \height320 \appleattachmentpadding0 \appleembedtype0 \appleaqc
}¬}\cf2 \cb3 \strokec2 \'a0Get the full playbook \uc0\u8594 </a><a href="{\field{\*\fldinst{HYPERLINK "https://wa.me/27744815163?text=Hi"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 https://wa.me/27744815163?text=Hi}}! I got a Hustle Score of $\{pct\}% and want to grow my business!" target="_blank" class="result-btn-wa">\cf2 \cb3 \strokec2 {{\NeXTGraphic Attachment.png \width320 \height320 \appleattachmentpadding0 \appleembedtype0 \appleaqc
}¬}\cf2 \cb3 \strokec2 \'a0Talk to an Expert</a><button class="result-btn-ghost" onclick="resetQuiz()">Retake Quiz</button></div>`;
\fs24 \

\fs20 \}
\fs24 \

\fs20 function resetQuiz() \{
\fs24 \

\fs20 qStep=0;qAnswers=[];
