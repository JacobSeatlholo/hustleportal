\fs20 const taglines = ['Explore. Adapt. Evolve.', 'Build. Launch. Scale.', 'Less friction. More revenue.'];
\fs24 \

\fs20 let tIdx = 0, cIdx = 0, typing = true;
\fs24 \

\fs20 const tagEl = document.getElementById('tagline');
\fs24 \

\fs20 function typeStep() \{
\fs24 \

\fs20 const cur = taglines[tIdx];
\fs24 \

\fs20 if (typing) \{
\fs24 \

\fs20 cIdx++;
\fs24 \

\fs20 tagEl.innerHTML = cur.slice(0, cIdx) + '<span class="cursor">|</span>';
\fs24 \

\fs20 if (cIdx >= cur.length) \{ typing = false; setTimeout(typeStep, 1800); return; \}
\fs24 \

\fs20 \} else \{
\fs24 \

\fs20 typing = true; cIdx = 0; tIdx = (tIdx + 1) % taglines.length;
\fs24 \

\fs20 \}
\fs24 \

\fs20 setTimeout(typeStep, typing ? 45 : 0);
\fs24 \

\fs20 \}
\fs24 \

\fs20 typeStep();
