\fs20 // \uc0\u9472 \u9472  AI CHAT \u9472 \u9472 
\fs24 \

\fs20 let chatOpen=false;
\fs24 \

\fs20 const chatMsgs=[];
\fs24 \

\fs20 function toggleChat()\{
\fs24 \

\fs20 chatOpen=!chatOpen;
\fs24 \

\fs20 document.getElementById('chatWrap').style.display=chatOpen?'flex':'none';
\fs24 \

\fs20 document.getElementById('aiBtn').classList.toggle('active',chatOpen);
\fs24 \

\fs20 \}
\fs24 \

\fs20 async function sendChat()\{
\fs24 \

\fs20 const inp=document.getElementById('chatInput');
\fs24 \

\fs20 const text=inp.value.trim();if(!text)return;
\fs24 \

\fs20 inp.value='';
\fs24 \

\fs20 addMsg('user',text);
\fs24 \

\fs20 chatMsgs.push(\{role:'user',content:text\});
\fs24 \

\fs20 const typing=addTyping();
\fs24 \

\fs20 try\{
\fs24 \

\fs20 const r=await fetch('{\field{\*\fldinst{HYPERLINK "https://api.anthropic.com/v1/messages"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 https://api.anthropic.com/v1/messages}}',\{method:'POST',headers:\{'Content-Type':'application/json'\},body:JSON.stringify(\{model:'claude-sonnet-4-20250514',max_tokens:1000,system:'You are an energetic, friendly business advisor for Business Hustle \'97 a South African digital startup agency at\'a0{\field{\*\fldinst{HYPERLINK "http://businesshustle.co.za/"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 businesshustle.co.za}}. Keep responses punchy and practical. Max 3 sentences. Use emojis occasionally.',messages:chatMsgs\})\});
\fs24 \

\fs20 const d=await r.json();
\fs24 \

\fs20 const reply=d.content?.[0]?.text||'Try again in a sec!';
\fs24 \

\fs20 chatMsgs.push(\{role:'assistant',content:reply\});
\fs24 \

\fs20 typing.remove();addMsg('bot',reply);
\fs24 \

\fs20 \}catch\{typing.remove();addMsg('bot','Connection hiccup! Try again\'a0\cf2 \cb3 \strokec2 {{\NeXTGraphic Attachment.png \width320 \height320 \appleattachmentpadding0 \appleembedtype0 \appleaqc
}¬}\cf2 \cb3 \strokec2 ');\}
\fs24 \

\fs20 \}
\fs24 \

\fs20 function addMsg(role,text)\{
\fs24 \

\fs20 const box=document.getElementById('chatMessages');
\fs24 \

\fs20 const d=document.createElement('div');d.className='msg '+role;
\fs24 \

\fs20 d.innerHTML=`<div class="msg-bubble">$\{text\}</div>`;
\fs24 \

\fs20 box.appendChild(d);box.scrollTop=box.scrollHeight;
\fs24 \

\fs20 return d;
\fs24 \

\fs20 \}
\fs24 \

\fs20 function addTyping()\{
\fs24 \

\fs20 const box=document.getElementById('chatMessages');
\fs24 \

\fs20 const d=document.createElement('div');d.className='typing';
\fs24 \

\fs20 d.innerHTML='<span></span><span></span><span></span>';
\fs24 \

\fs20 box.appendChild(d);box.scrollTop=box.scrollHeight;
\fs24 \

\fs20 return d;
\fs24 \

\fs20 \}
\fs24 \

\fs20 </script>
